rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 사용자 본인 데이터만 읽기/쓰기 가능
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 기존 storyboards 컬렉션 (레거시 — Admin SDK로 직접 저장하던 것)
    match /storyboards/{docId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow write: if false; // 서버 Admin SDK 전용
    }

    // 피드 게시물 — 누구나 읽기, 로그인 사용자만 작성, 본인만 삭제
    match /feedPosts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes','views','updatedAt'])
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // 즐겨찾기 — 누구나 읽기, 로그인 사용자만 생성, 본인만 수정·삭제
    match /favorites/{favId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // 포스터(공모전/프로젝트) — 누구나 읽기, 로그인 사용자만 생성, 본인만 수정·삭제
    match /posters/{posterId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // 포스트잇 메모 — 누구나 읽기, 로그인 사용자만 생성, 본인만 수정·삭제
    match /stickyNotes/{noteId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // 투두 — 누구나 읽기, 로그인 사용자만 생성, 본인만 수정·삭제
    match /todos/{todoId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // 지도 보드 — 누구나 읽기, 로그인 사용자만 생성, 개설자만 수정·삭제
    match /mapBoards/{boardId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uid;
      // 개설자는 전체 수정 / 일반 참여자는 postCount·updatedAt만
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['postCount','updatedAt'])
      );

      // 지도 핀(게시물) — 누구나 읽기, 로그인 사용자만 등록, 작성자·개설자만 수정·삭제
      match /posts/{postId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && (
          request.auth.uid == resource.data.uid ||
          request.auth.uid == get(/databases/$(database)/documents/mapBoards/$(boardId)).data.uid
        );
      }
    }

    // 액션보드 — 누구나 읽기, 로그인 사용자만 생성
    match /actionBoards/{boardId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uid;
      // 보드 개설자: 모든 필드 수정 가능 / 일반 참여자: postCount·updatedAt·order만 수정 가능(순서 변경)
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['postCount','updatedAt','order'])
      );

      // 게시물 — 누구나 읽기, 로그인 사용자만 등록
      match /posts/{postId} {
        allow read: if true;
        allow create: if request.auth != null;
        // 수정: 작성자 또는 보드 개설자는 전체 수정 / 그 외 로그인 사용자는 위치(x,y)만 이동 가능
        allow update: if request.auth != null && (
          request.auth.uid == resource.data.uid ||
          request.auth.uid == get(/databases/$(database)/documents/actionBoards/$(boardId)).data.uid ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['x','y']) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount'])
        );
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.uid ||
          request.auth.uid == get(/databases/$(database)/documents/actionBoards/$(boardId)).data.uid
        );

        // 댓글 — 누구나 읽기, 로그인 사용자만 등록, 본인·보드 개설자만 삭제
        match /comments/{commentId} {
          allow read: if true;
          allow create: if request.auth != null;
          allow delete: if request.auth != null && (
            request.auth.uid == resource.data.uid ||
            request.auth.uid == get(/databases/$(database)/documents/actionBoards/$(boardId)).data.uid
          );
        }
      }
    }
  }
}
