rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 사용자 본인 파일만 읽기/쓰기 가능
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 액션보드 이미지 — 로그인 사용자 업로드, 누구나 읽기
    match /actionboards/{boardId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 포스터 이미지 — 로그인 사용자 업로드, 누구나 읽기
    match /posters/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 지도 보드 이미지 — 로그인 사용자 업로드, 누구나 읽기
    match /mapboards/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // SRT 임시 오디오 — 본인 폴더만 업로드 (서버가 처리 후 즉시 삭제)
    match /srt_temp/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
